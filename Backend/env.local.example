# Copia questo file in `env.local` e inserisci le tue chiavi reali.
# `env.local` è in .gitignore: non verrà mai committato.
# In produzione (Render) le stesse variabili si impostano nella dashboard.

# --- OpenAI ---
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini          # Opzioni: gpt-4o, gpt-4o-mini

# --- Gemini ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash     # Opzioni: gemini-1.5-flash, gemini-1.5-pro

# --- AI Provider ---
AI_PROVIDER=auto                  # Opzioni: openai, gemini, auto, local

# --- Ambiente ---
ENVIRONMENT=development
DEBUG=true
